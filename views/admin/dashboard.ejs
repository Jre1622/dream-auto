<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dream Auto Admin</title>
  <link href="/css/output.css" rel="stylesheet">
</head>
<body class="bg-gray-100 min-h-screen">
  <% const available = cars.filter(car => !car.sold).length; %>
  <% const sold = cars.filter(car => car.sold).length; %>
  <% const featured = cars.filter(car => car.is_featured).length; %>

  <main class="max-w-7xl mx-auto px-4 py-8">
    <header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
      <div>
        <p class="text-sm text-gray-500">Dream Auto</p>
        <h1 class="text-3xl font-bold text-gray-900">Inventory Admin</h1>
      </div>
      <div class="flex gap-3">
        <a href="/" class="bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-50">View Site</a>
        <a href="/admin/add-car" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">Add Vehicle</a>
      </div>
    </header>

    <% if (error) { %><div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-6"><%= error %></div><% } %>

    <section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-xl border border-gray-200 p-4"><p class="text-sm text-gray-500">Total</p><p class="text-2xl font-bold"><%= cars.length %></p></div>
      <div class="bg-white rounded-xl border border-gray-200 p-4"><p class="text-sm text-gray-500">Available</p><p class="text-2xl font-bold text-green-700"><%= available %></p></div>
      <div class="bg-white rounded-xl border border-gray-200 p-4"><p class="text-sm text-gray-500">Sold</p><p class="text-2xl font-bold text-red-700"><%= sold %></p></div>
      <div class="bg-white rounded-xl border border-gray-200 p-4"><p class="text-sm text-gray-500">Featured</p><p class="text-2xl font-bold text-yellow-700"><%= featured %></p></div>
    </section>

    <section class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="p-4 border-b border-gray-200 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <h2 class="font-semibold text-gray-900">Vehicles</h2>
        <input id="vehicleSearch" class="w-full sm:w-80 px-3 py-2 border border-gray-300 rounded-lg" placeholder="Search title, VIN, make, model...">
      </div>

      <% if (!cars.length) { %>
        <div class="p-10 text-center">
          <p class="text-gray-600 mb-4">No vehicles yet.</p>
          <a href="/admin/add-car" class="inline-flex bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">Add First Vehicle</a>
        </div>
      <% } else { %>
        <div class="divide-y divide-gray-200" id="vehicleList">
          <% cars.forEach(car => { %>
            <article class="vehicle-row p-4 flex flex-col gap-4 md:flex-row md:items-center" data-search="<%= `${car.title} ${car.vin} ${car.year} ${car.make} ${car.model}`.toLowerCase() %>">
              <img class="w-full md:w-32 h-28 object-cover rounded-lg bg-gray-100" src="<%= car.primary_image %>" alt="<%= car.title %>" onerror="this.src='/images/placeholder-car.svg'">

              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <h3 class="font-semibold text-gray-900"><%= car.year %> <%= car.make %> <%= car.model %></h3>
                  <% if (car.sold) { %><span class="text-xs bg-red-100 text-red-800 px-2 py-1 rounded-full">Sold</span><% } else { %><span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full">Available</span><% } %>
                  <% if (car.is_featured) { %><span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded-full">Featured</span><% } %>
                </div>
                <p class="text-sm text-gray-600"><%= car.title %></p>
                <p class="text-sm text-gray-500">VIN: <%= car.vin %></p>
                <p class="text-sm text-gray-500"><%= car.mileage.toLocaleString() %> miles<%= car.transmission ? ` · ${car.transmission}` : '' %></p>
              </div>

              <div class="md:text-right">
                <p class="text-xl font-bold text-gray-900 mb-3">$<%= car.price.toLocaleString() %></p>
                <div class="flex flex-wrap gap-2 md:justify-end">
                  <a href="/admin/edit-car/<%= car.id %>" class="px-3 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700">Edit</a>
                  <form method="POST" action="/admin/toggle-sold/<%= car.id %>"><button class="px-3 py-2 bg-white border border-gray-300 text-sm rounded-lg hover:bg-gray-50"><%= car.sold ? 'Mark Available' : 'Mark Sold' %></button></form>
                  <form method="POST" action="/admin/delete-car/<%= car.id %>" onsubmit="return confirm('Delete this vehicle? This cannot be undone.')"><button class="px-3 py-2 bg-white border border-red-200 text-red-700 text-sm rounded-lg hover:bg-red-50">Delete</button></form>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>

  <script>
    const search = document.getElementById('vehicleSearch');
    search?.addEventListener('input', () => {
      const term = search.value.trim().toLowerCase();
      document.querySelectorAll('.vehicle-row').forEach(row => {
        row.classList.toggle('hidden', term && !row.dataset.search.includes(term));
      });
    });
  </script>
</body>
</html>
