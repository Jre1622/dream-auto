<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Vehicle - Dream Auto Admin</title>
  <link href="/css/output.css" rel="stylesheet">
</head>
<body class="bg-gray-100 min-h-screen">
  <main class="max-w-5xl mx-auto px-4 py-8">
    <header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
      <div>
        <p class="text-sm text-gray-500">Admin / Inventory</p>
        <h1 class="text-3xl font-bold text-gray-900">Edit Vehicle</h1>
        <p class="text-gray-600 mt-1"><%= car.year %> <%= car.make %> <%= car.model %></p>
      </div>
      <div class="flex gap-3">
        <a href="/inventory/<%= car.id %>" class="inline-flex justify-center bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-50">View Listing</a>
        <a href="/admin" class="inline-flex justify-center bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-50">Dashboard</a>
      </div>
    </header>

    <% if (success) { %><div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mb-6"><%= success %></div><% } %>
    <% if (error) { %><div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-6"><%= error %></div><% } %>

    <%- include('partials/car-form', { mode: 'edit', car, images }) %>
  </main>
</body>
</html>
