<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error - Dream Auto</title>
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center px-4">
  <main class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-md w-full text-center">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Something went wrong</h1>
    <p class="text-gray-600 mb-6"><%= message || 'Please try again.' %></p>
    <a href="/" class="inline-flex bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">Go Home</a>
  </main>
</body>
</html>
